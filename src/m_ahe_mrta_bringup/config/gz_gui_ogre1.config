<?xml version="1.0"?>
<!--
  Gazebo Harmonic GUI config for SOFTWARE rendering (llvmpipe / no GPU driver).
  Uses the OGRE 1.x render engine (engine=ogre) and a minimal plugin set.
  The default Gazebo GUI crashes under llvmpipe in two ways:
    - OGRE2 (default)  -> EGL driCreateNewScreen3 segfault
    - OGRE1 + default Grid3D plugin -> OgreDynamicLines::FillHardwareBuffers segfault
  This config drops the standalone Grid3D plugin; GzSceneManager renders the
  scene (robots, obstacles) coming from the server. Bird's-eye camera framed
  on the 20x20 m inspection arena (centred at origin).
  Launch with: gz sim --render-engine-gui ogre --gui-config <this file>
-->
<window>
  <width>1920</width>
  <height>1080</height>
  <style material_theme="Light" material_primary="DeepOrange" material_accent="LightBlue"/>
</window>

<plugin filename="MinimalScene" name="3D View">
  <gz-gui>
    <title>3D View</title>
    <property type="bool" key="showTitleBar">false</property>
    <property type="string" key="state">docked</property>
  </gz-gui>
  <engine>ogre</engine>
  <scene>scene</scene>
  <ambient_light>0.5 0.5 0.5</ambient_light>
  <background_color>0.85 0.87 0.9</background_color>
  <!-- Dead top-down framing of the complete 20x20 m arena, yaw-aligned with
       the RViz map view so the Gazebo/RViz figure pair overlays exactly.
       z=40 is required: at the 3D view's ~1.98 aspect the arena only fits
       fully inside the frame from that height. -->
  <camera_pose>0 0 40 0 1.5708 1.5708</camera_pose>
</plugin>

<plugin filename="GzSceneManager" name="Scene Manager">
  <gz-gui>
    <property key="showTitleBar" type="bool">false</property>
    <property key="state" type="string">floating</property>
    <property key="width" type="double">5</property>
    <property key="height" type="double">5</property>
    <property key="showDockButton" type="bool">false</property>
  </gz-gui>
</plugin>

<plugin filename="InteractiveViewControl" name="Interactive view control">
  <gz-gui>
    <property key="resizable" type="bool">false</property>
    <property key="width" type="double">5</property>
    <property key="height" type="double">5</property>
    <property key="state" type="string">floating</property>
    <property key="showTitleBar" type="bool">false</property>
  </gz-gui>
</plugin>
