    {
      "id": "0ce9uvw53efr4edt",
      "type": "text",
      "x": 284,
      "y": 234,
      "width": 499.65999999999997,
      "height": 106,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
