      "updated": 1782051500909,
      "link": null,
      "locked": false,
      "text": "Publish per-robot task queues   ->   Nav2 execution\n\nwork-conserving: no idle robot while feasible work remains\na disturbance costs at most a re-attempt, never a lost task",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "Publish per-robot task queues   ->   Nav2 execution\n\nwork-conserving: no idle robot while feasible work remains\na disturbance costs at most a re-attempt, never a lost task",
      "lineHeight": 1.3,
      "baseline": 15
    },
