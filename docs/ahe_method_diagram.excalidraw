      "frameId": null,
      "roundness": null,
      "seed": 649677952,
      "versionNonce": 435786141,
      "version": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782051500909,
      "link": null,
      "locked": false,
      "text": "EDPS dispatch   ->   selected paradigm  p*\n\noverride 1:  c4 (failure)  > 0.05  =>  H_RECOV\noverride 2:  c3 (deadline) > 0.50  =>  H_TEMP\notherwise:   p* = argmax_i D_i    (default H_TEMP if D flat)",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "EDPS dispatch   ->   selected paradigm  p*\n\noverride 1:  c4 (failure)  > 0.05  =>  H_RECOV\noverride 2:  c3 (deadline) > 0.50  =>  H_TEMP\notherwise:   p* = argmax_i D_i    (default H_TEMP if D flat)",
      "lineHeight": 1.3,
      "baseline": 15
    },
    {
      "id": "xbenyjqwx4hh5344",
