    {
      "id": "zzg4zdmen2khvdga",
      "type": "text",
      "x": 284,
      "y": 664,
      "width": 499.65999999999997,
      "height": 85,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
