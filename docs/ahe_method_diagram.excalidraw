    {
      "id": "jgvq4k7bn7xj8b7t",
      "type": "text",
      "x": 284,
      "y": 837,
      "width": 499.65999999999997,
      "height": 127,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
