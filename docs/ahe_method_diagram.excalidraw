      "updated": 1782051500909,
      "link": null,
      "locked": false,
      "text": "Fleet + Task state   @ event t_k\n\nrobots  R = {r_1 .. r_n}   (pose, battery, status)\nopen tasks  T(t_k)   (pos, deadline d, priority pi, capability c)",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "Fleet + Task state   @ event t_k\n\nrobots  R = {r_1 .. r_n}   (pose, battery, status)\nopen tasks  T(t_k)   (pos, deadline d, priority pi, capability c)",
      "lineHeight": 1.3,
      "baseline": 15
    },
