      "seed": 1914012529,
      "versionNonce": 1222328496,
      "version": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782051500909,
      "link": null,
      "locked": false,
      "text": "Operating State Vector   c(t_k) in [0,1]^4\n\nc1  task density        = min(1, m / n)\nc2  robot availability  = |R_av| / n\nc3  deadline pressure   = #{near-deadline tasks} / m\nc4  failure rate        = |R_fail| / n",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "Operating State Vector   c(t_k) in [0,1]^4\n\nc1  task density        = min(1, m / n)\nc2  robot availability  = |R_av| / n\nc3  deadline pressure   = #{near-deadline tasks} / m\nc4  failure rate        = |R_fail| / n",
      "lineHeight": 1.3,
      "baseline": 15
    },
    {
